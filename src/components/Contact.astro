---


const contactInfo = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8Z"/></svg>`,
    label: 'Teléfono',
    value: '+593 00 000 0000',
    href: 'tel:+593000000000',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347Z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.05L.785 23.493a.5.5 0 0 0 .622.622l4.443-1.499A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0Z" fill="currentColor" opacity=".15"/></svg>`,
    label: 'WhatsApp',
    value: '+593 00 000 0000',
    href: 'https://wa.me/593000000000',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    label: 'Correo',
    value: 'info@electrolife.ec',
    href: 'mailto:info@electrolife.ec',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    label: 'Ubicación',
    value: 'Quito, Ecuador',
    href: 'https://maps.google.com',
  },
];

const services = [
  'Instalación eléctrica',
  'Reparación urgente',
  'Mantenimiento',
  'Iluminación LED',
  'Sistema de seguridad',
  'Automatización / Smart home',
  'Otro',
];
---

<section class="contact section" id="contacto">
  <div class="container">

    <header class="contact__header">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">
        ¿Listo para empezar? <br/>
        <span>Cuéntanos tu proyecto</span>
      </h2>
      <p class="contact__subtitle">
        Escríbenos o llámanos y recibirás una cotización sin costo en menos de 24 horas.
      </p>
    </header>

    <div class="contact__inner">

      <!-- Info panel -->
      <aside class="contact__info">
        <ul class="contact__info-list">
          {contactInfo.map(item => (
            <li>
              <a href={item.href} class="contact__info-item" target={item.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
                <div class="contact__info-icon" set:html={item.icon} />
                <div>
                  <p class="contact__info-label">{item.label}</p>
                  <p class="contact__info-value">{item.value}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>

        <!-- Social links -->
        <div class="contact__socials">
          <p class="contact__socials-label">Síguenos</p>
          <div class="contact__social-links">
            <a href="https://facebook.com" target="_blank" rel="noopener" class="contact__social" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener" class="contact__social" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="20" x="2" y="2" rx="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
              </svg>
            </a>
            <a href="https://tiktok.com" target="_blank" rel="noopener" class="contact__social" aria-label="TikTok">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.61a8.18 8.18 0 0 0 4.78 1.53V6.69a4.85 4.85 0 0 1-1.01-.00Z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Availability badge -->
        <div class="contact__availability">
          <span class="contact__availability-dot"></span>
          <span>Disponible 24 horas, 7 días a la semana</span>
        </div>
      </aside>

      <!-- Form -->
      <div class="contact__form-wrap">
        <form class="contact__form" id="contactForm" novalidate>

          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Nombre completo *</label>
              <input
                type="text"
                id="name"
                name="name"
                class="form-input"
                placeholder="Juan Pérez"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="phone" class="form-label">Teléfono *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="form-input"
                placeholder="+593 99 999 9999"
                required
                autocomplete="tel"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="tu@correo.com"
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label for="service" class="form-label">Tipo de servicio *</label>
            <div class="form-select-wrap">
              <select id="service" name="service" class="form-input form-select" required>
                <option value="" disabled selected>Selecciona un servicio</option>
                {services.map(s => <option value={s}>{s}</option>)}
              </select>
              <svg class="form-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Describe tu problema o proyecto *</label>
            <textarea
              id="message"
              name="message"
              class="form-input form-textarea"
              placeholder="Cuéntanos qué necesitas, la dirección aproximada y cualquier detalle relevante..."
              rows="4"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--lg form-submit" id="submitBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/>
            </svg>
            Enviar mensaje
          </button>

          <p class="form-note">
            También puedes escribirnos directamente por 
            <a href="https://wa.me/593000000000" target="_blank" rel="noopener">WhatsApp</a>
          </p>

          <!-- Success message -->
          <div class="form-success" id="formSuccess" aria-live="polite">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--clr-primary)">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <p>¡Mensaje enviado! Te contactaremos pronto.</p>
          </div>

        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact__header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 4rem;
  }

  .contact__header .section-label { justify-content: center; }

  .contact__subtitle {
    margin-top: 1rem;
    color: var(--clr-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  /* Layout */
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 3rem;
    align-items: start;
  }

  /* Info */
  .contact__info {
    padding: 2.5rem;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: 14px;
    position: sticky;
    top: 6rem;
  }

  .contact__info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .contact__info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem;
    border-radius: 8px;
    transition: background 0.2s;
    color: var(--clr-text);
  }

  .contact__info-item:hover { background: rgba(0,200,255,0.06); }

  .contact__info-icon {
    flex-shrink: 0;
    width: 44px; height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,200,255,0.08);
    border: 1px solid rgba(0,200,255,0.15);
    border-radius: 9px;
    color: var(--clr-primary);
  }

  .contact__info-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
    margin-bottom: 0.2rem;
  }

  .contact__info-value {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--clr-text);
  }

  /* Socials */
  .contact__socials { margin-bottom: 1.5rem; }

  .contact__socials-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
    margin-bottom: 0.75rem;
  }

  .contact__social-links {
    display: flex;
    gap: 0.6rem;
  }

  .contact__social {
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    color: var(--clr-text-muted);
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .contact__social:hover {
    color: var(--clr-primary);
    border-color: rgba(0,200,255,0.35);
    box-shadow: var(--glow-sm);
  }

  /* Availability */
  .contact__availability {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--clr-text-muted);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .contact__availability-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--clr-accent);
    box-shadow: 0 0 8px var(--clr-accent);
    animation: pulse-glow 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Form */
  .contact__form-wrap {
    padding: 2.5rem;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: 14px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
  }

  .form-input {
    background: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    color: var(--clr-text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
    appearance: none;
  }

  .form-input::placeholder { color: var(--clr-text-muted); opacity: 0.5; }

  .form-input:focus {
    outline: none;
    border-color: var(--clr-primary);
    box-shadow: 0 0 0 3px rgba(0,200,255,0.1);
  }

  .form-input.error { border-color: var(--clr-danger); }

  .form-select-wrap { position: relative; }

  .form-select {
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .form-select-arrow {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--clr-text-muted);
    pointer-events: none;
  }

  .form-textarea { resize: vertical; min-height: 100px; }

  .form-submit { width: 100%; justify-content: center; }

  .form-note {
    text-align: center;
    font-size: 0.83rem;
    color: var(--clr-text-muted);
  }

  .form-note a {
    color: var(--clr-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Success */
  .form-success {
    display: none;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(0,200,255,0.07);
    border: 1px solid rgba(0,200,255,0.25);
    border-radius: 8px;
    color: var(--clr-text);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .form-success.visible { display: flex; }

  @media (max-width: 900px) {
    .contact__inner { grid-template-columns: 1fr; }
    .contact__info  { position: static; }
  }

  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form      = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const success   = document.getElementById('formSuccess')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic validation
    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((field) => {
      const el = field as HTMLInputElement;
      el.classList.remove('error');
      if (!el.value.trim()) {
        el.classList.add('error');
        valid = false;
      }
    });

    if (!valid) return;

    // Simulate submission (replace with your actual endpoint / EmailJS / Formspree)
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    await new Promise(r => setTimeout(r, 1200));

    form.reset();
    success.classList.add('visible');
    submitBtn.disabled = false;
    submitBtn.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/></svg>
      Enviar mensaje
    `;

    setTimeout(() => success.classList.remove('visible'), 5000);
  });
</script>
