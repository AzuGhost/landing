---

const navLinks = [
  { label: 'Inicio',    href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros',  href: '#nosotros' },
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Contacto',  href: '#contacto' },
];
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">

    <!-- Logo -->
    <a href="#inicio" class="navbar__logo" aria-label="Electro Life">
      
      <img
        src="/images/logo.png"
        alt="Electro Life"
        width="44"
        height="44"
        class="navbar__logo-img"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <span class="navbar__logo-fallback" style="display:none">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <path d="M13 2L4.09 12.11h7.91L10 22l9.9-10.24H12.5L13 2Z"
                fill="var(--clr-primary)" stroke="var(--clr-primary)"
                stroke-width="0.5"/>
        </svg>
      </span>
      <span class="navbar__brand">
        ELECTRO <strong>LIFE</strong>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="navbar__nav" aria-label="Navegación principal">
      <ul class="navbar__links">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="navbar__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <a href="tel:+593000000000" class="btn btn--primary navbar__cta">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8Z"/>
      </svg>
      Llamar ahora
    </a>

    <!-- Hamburger -->
    <button class="navbar__hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile Menu -->
  <div class="navbar__mobile" id="mobileMenu" aria-hidden="true">
    <ul class="navbar__mobile-links">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="navbar__mobile-link">{link.label}</a>
        </li>
      ))}
    </ul>
    <a href="tel:+593000000000" class="btn btn--primary" style="width:100%;text-align:center;margin-top:1rem">
      Llamar ahora
    </a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    transition: background 0.3s ease, box-shadow 0.3s ease;
    padding-block: 1rem;
  }

  .navbar.scrolled {
    background: rgba(2, 11, 24, 0.95);
    backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 var(--clr-border), 0 4px 30px rgba(0,0,0,0.5);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
  }

  .navbar__logo-img {
    width: 44px; height: 44px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(0,200,255,0.6));
  }

  .navbar__logo-fallback {
    align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border: 1px solid var(--clr-border);
    border-radius: 6px;
    background: var(--clr-surface);
  }

  .navbar__brand {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--clr-text);
    line-height: 1.1;
  }

  .navbar__brand strong {
    color: var(--clr-primary);
    font-weight: 700;
    text-shadow: var(--glow-sm);
  }

  /* Nav */
  .navbar__nav { margin-left: auto; }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .navbar__link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.85rem;
    border-radius: 4px;
    color: var(--clr-text-muted);
    transition: color 0.2s, background 0.2s;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%; right: 50%;
    height: 1px;
    background: var(--clr-primary);
    box-shadow: var(--glow-sm);
    transition: left 0.25s var(--ease-out), right 0.25s var(--ease-out);
  }

  .navbar__link:hover {
    color: var(--clr-text);
  }

  .navbar__link:hover::after {
    left: 0.85rem; right: 0.85rem;
  }

  /* CTA */
  .navbar__cta { flex-shrink: 0; }

  /* Hamburger */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .navbar__hamburger span {
    display: block;
    width: 24px; height: 2px;
    background: var(--clr-primary);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .navbar__hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .navbar__hamburger.open span:nth-child(2) { opacity: 0; }
  .navbar__hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile Menu */
.navbar__mobile {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  visibility: hidden;
  transition:
    max-height 0.4s var(--ease-out),
    opacity    0.3s ease,
    visibility 0s   linear 0.4s; 
  background: rgba(4, 15, 31, 0.98);
  border-top: 1px solid var(--clr-border);
}

.navbar__mobile.open {
  max-height: 500px;
  opacity: 1;
  visibility: visible;
  transition:
    max-height 0.4s var(--ease-out),
    opacity    0.3s ease,
    visibility 0s   linear 0s;  
}

  .navbar__mobile-links { list-style: none; }

  .navbar__mobile-link {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.75rem 0;
    color: var(--clr-text-muted);
    border-bottom: 1px solid var(--clr-border);
    transition: color 0.2s;
  }

  .navbar__mobile-link:hover { color: var(--clr-primary); }

  /* Shared button */
  :global(.btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.6rem 1.35rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
    text-transform: uppercase;
  }

  :global(.btn--primary) {
    background: var(--clr-primary);
    color: var(--clr-bg);
    box-shadow: var(--glow-sm);
  }

  :global(.btn--primary:hover) {
    background: var(--clr-accent);
    box-shadow: var(--glow-md);
    transform: translateY(-1px);
  }

  :global(.btn--outline) {
    background: transparent;
    color: var(--clr-primary);
    border: 1px solid var(--clr-primary);
    box-shadow: var(--glow-sm);
  }

  :global(.btn--outline:hover) {
    background: rgba(0,200,255,0.08);
    box-shadow: var(--glow-md);
    transform: translateY(-1px);
  }

  :global(.btn--lg) {
    padding: 0.85rem 2rem;
    font-size: 1rem;
  }

  @media (max-width: 900px) {
    .navbar__nav, .navbar__cta { display: none; }
    .navbar__hamburger { display: flex; }
    .navbar__mobile { display: block; }
  }
</style>

<script>
  const navbar    = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobile    = document.getElementById('mobileMenu')!;

  // Scroll effect
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Mobile toggle
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobile.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobile.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close on link click
  mobile.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobile.classList.remove('open');
    });
  });
</script>
