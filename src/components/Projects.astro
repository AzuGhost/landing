---

const projects = [
  { img: '/images/projects/project-1.jpg', title: 'Instalación Residencial', tag: 'Residencial', span: 'col' },
  { img: '/images/projects/project-2.jpg', title: 'Tablero Eléctrico',       tag: 'Industrial',  span: '' },
  { img: '/images/projects/project-3.jpg', title: 'Iluminación LED Comercial', tag: 'Comercial', span: '' },
  { img: '/images/projects/project-4.jpg', title: 'Sistema CCTV',            tag: 'Seguridad',   span: '' },
  { img: '/images/projects/project-5.jpg', title: 'Automatización Hogar',    tag: 'Smart Home',  span: '' },
  { img: '/images/projects/project-6.jpg', title: 'Mantenimiento Industrial', tag: 'Industrial', span: 'col' },
];
---

<section class="projects section" id="proyectos">
  <div class="container">

    <header class="projects__header">
      <p class="section-label">Nuestros Proyectos</p>
      <h2 class="section-title">
        Trabajos que <span>hablan</span> <br/>por sí solos
      </h2>
    </header>

    <div class="projects__grid">
      {projects.map((project, i) => (
        <figure
          class={`project-item ${project.span === 'col' ? 'project-item--span' : ''}`}
          data-index={i}
        >
          <img
            src={project.img}
            alt={project.title}
            class="project-item__img"
            loading="lazy"
            onerror="this.parentElement.classList.add('project-item--fallback')"
          />
          <figcaption class="project-item__overlay">
            <span class="project-item__tag">{project.tag}</span>
            <h3 class="project-item__title">{project.title}</h3>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="projects__cta">
      <p>¿Tienes un proyecto en mente?</p>
      <a href="#contacto" class="btn btn--outline btn--lg">
        Solicita tu cotización gratis
      </a>
    </div>

  </div>
</section>

<style>
  .projects__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .projects__header .section-label { justify-content: center; }

  /* Grid */
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 280px;
    gap: 1rem;
  }

  .project-item--span { grid-row: span 2; }

  /* Card */
  .project-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    cursor: pointer;
  }

  .project-item__img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out), filter 0.4s;
    filter: brightness(0.85) saturate(0.9);
  }

  .project-item:hover .project-item__img {
    transform: scale(1.05);
    filter: brightness(0.7) saturate(1.1);
  }

  /* Fallback */
  .project-item--fallback {
    background: linear-gradient(135deg, var(--clr-surface), var(--clr-surface-2));
  }

  /* Overlay */
  .project-item__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(2,11,24,0.9) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.35s;
  }

  .project-item:hover .project-item__overlay { opacity: 1; }

  .project-item__tag {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clr-primary);
    text-shadow: var(--glow-sm);
    margin-bottom: 0.4rem;
  }

  .project-item__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--clr-text);
  }

  /* Bottom CTA */
  .projects__cta {
    text-align: center;
    margin-top: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .projects__cta p {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--clr-text-muted);
  }

  @media (max-width: 900px) {
    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
    .project-item--span { grid-row: span 1; }
  }

  @media (max-width: 580px) {
    .projects__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 240px;
    }
  }
</style>
