---
// src/layouts/BaseLayout.astro
import type { meta } from 'astro:schema';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Electro Life — Servicios Eléctricos Profesionales',
  description = 'Instalaciones eléctricas, reparaciones y mantenimiento. Servicio 24/7 con garantía. Técnicos certificados a tu disposición.',
  ogImage = '/og-image.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
